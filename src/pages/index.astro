---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mahdi Hooshmand | Network & Infrastructure Specialist">

  <!-- LOADER -->
  <div class="loader" id="loader">
    <div class="loader-inner">
      <span class="loader-name">MAHDI HOOSHMAND</span>
      <div class="loader-bar"><div class="loader-fill"></div></div>
      <span class="loader-status">INITIALIZING...</span>
    </div>
  </div>

  <main>

    <!-- HEADER -->
    <header class="site-header" id="site-header">
      <div class="container-x header-inner">
        <a href="/" class="brand">MAHDI<span class="accent-dot">.</span></a>
        <nav class="header-nav" id="header-nav">
          <a href="#about" class="nav-link">About</a>
          <a href="#skills" class="nav-link">Skills</a>
          <a href="#experience" class="nav-link">Experience</a>
          <a href="#projects" class="nav-link">Projects</a>
          <a href="#contact" class="nav-link nav-cta">Contact</a>
        </nav>
        <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <!-- HERO -->
    <section id="about" class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container-x hero-content">
        <div class="hero-text">
          <div class="hero-eyebrows">
            <span class="eyebrow">Mashhad, Iran</span>
            <span class="eyebrow-sep">/</span>
            <span class="eyebrow">Network & Infrastructure</span>
            <span class="eyebrow-sep">/</span>
            <span class="eyebrow">VoIP & ERP</span>
          </div>
          <h1>
            <span class="name-first">Mahdi</span>
            <span class="name-last">Hooshmand</span>
          </h1>
          <p class="hero-desc">
            Building and maintaining reliable network infrastructure, VoIP systems,
            and server environments. 5+ years of hands-on experience turning complex
            technical challenges into stable, scalable solutions.
          </p>
          <div class="hero-actions">
            <a href="#projects" class="btn btn-accent">View Projects</a>
            <a href="#contact" class="btn btn-outline">Get In Touch</a>
          </div>
          <a href="#skills" class="scroll-hint">
            <span class="scroll-line"></span>
            <span>Explore my work</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section-space border-t about-bg">
      <div class="container-x">
        <div class="about-layout">
          <div class="about-left">
            <span class="section-label">About</span>
            <h2 class="section-title">I solve complex technical problems and build reliable systems.</h2>
            <p class="about-text">
              With over 5 years of hands-on experience in IT infrastructure, I've built deep expertise
              across networking, VoIP, server virtualization, and enterprise resource planning. My work
              spans from designing secure network architectures and deploying VoIP solutions for hotels
              and call centers, to implementing Odoo ERP systems and managing Linux-based server environments.
            </p>
            <p class="about-text">
              I enjoy solving complex technical problems and building reliable systems that help businesses
              operate more efficiently. My mission is to simplify technology for organizations by designing
              infrastructure, automation, and business systems that are stable, scalable, and easy to maintain.
              I am particularly interested in bridging the gap between IT infrastructure and business processes.
            </p>
            <p class="about-text">
              Unlike specialists who focus solely on infrastructure, I combine experience in networking,
              Linux administration, virtualization, VoIP systems, databases, and ERP customization. This
              allows me to understand both the technical foundation and the business processes that rely on it.
              I can communicate with business stakeholders and translate operational requirements into
              practical technical solutions.
            </p>
            <div class="skill-badges-inline">
              <span class="skill-badge">MikroTik</span>
              <span class="skill-badge">Cisco</span>
              <span class="skill-badge">Asterisk</span>
              <span class="skill-badge">Linux</span>
              <span class="skill-badge">VMware</span>
              <span class="skill-badge">Docker</span>
              <span class="skill-badge">Odoo</span>
              <span class="skill-badge">SQL</span>
              <span class="skill-badge">VoIP</span>
              <span class="skill-badge">VPN</span>
              <span class="skill-badge">Firewall</span>
            </div>
          </div>
          <div class="about-right">
            <div class="about-card">
              <span class="section-label">My Mission</span>
              <p>To simplify technology for organizations by designing infrastructure, automation, and business
              systems that are stable, scalable, and easy to maintain — bridging the gap between IT infrastructure
              and business processes.</p>
            </div>
            <div class="about-card">
              <span class="section-label">My Vision</span>
              <p>To become a solutions architect who can design complete business platforms — from infrastructure
              and virtualization to ERP systems and process automation. I believe the future of IT is in
              integrating infrastructure, cloud technologies, automation, and business applications into
              unified solutions that reduce complexity and increase productivity.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="section-space border-t">
      <div class="container-x">
        <div class="skills-layout">
          <div class="skills-left">
            <span class="section-label">Core Skills</span>
            <h2 class="section-title">What I Work With</h2>
            <p class="caveat">Specialized in building and managing IT infrastructure for businesses.</p>
            <div class="skills-text">
              <p>
                With over 5 years of hands-on experience, I've developed deep expertise across
                multiple domains of IT infrastructure. My work spans from designing secure network
                architectures to deploying enterprise communication systems and managing complex
                server environments.
              </p>
              <div class="skill-badges-inline">
                <span class="skill-badge">MikroTik</span>
                <span class="skill-badge">Cisco</span>
                <span class="skill-badge">Asterisk</span>
                <span class="skill-badge">Issabel</span>
                <span class="skill-badge">Windows Server</span>
                <span class="skill-badge">Linux</span>
                <span class="skill-badge">VMware</span>
                <span class="skill-badge">Docker</span>
                <span class="skill-badge">Odoo</span>
                <span class="skill-badge">SQL</span>
                <span class="skill-badge">VoIP</span>
                <span class="skill-badge">VPN</span>
                <span class="skill-badge">Firewall</span>
              </div>
            </div>
          </div>
          <div class="skills-right">
            <div class="skill-category-card">
              <h3>Networking</h3>
              <p>MikroTik (MTCNA), Cisco, VLAN, NAT, Firewall, VPN, LAN/WAN, Advanced Troubleshooting</p>
              <div class="skill-tags">
                <span class="tag">MikroTik</span>
                <span class="tag">Cisco</span>
                <span class="tag">Firewall</span>
                <span class="tag">VPN</span>
              </div>
            </div>
            <div class="skill-category-card">
              <h3>VoIP Systems</h3>
              <p>Asterisk, Issabel, SIP Trunk, IVR, Call Queue, Call Center Setup, FXO/FXS Configuration</p>
              <div class="skill-tags">
                <span class="tag">Asterisk</span>
                <span class="tag">Issabel</span>
                <span class="tag">SIP</span>
                <span class="tag">IVR</span>
              </div>
            </div>
            <div class="skill-category-card">
              <h3>Servers & Virtualization</h3>
              <p>Windows Server (AD, DNS, DHCP), Linux (Debian, Ubuntu), VMware ESXi, Backup Strategy</p>
              <div class="skill-tags">
                <span class="tag">Windows Server</span>
                <span class="tag">Linux</span>
                <span class="tag">VMware</span>
                <span class="tag">ESXi</span>
              </div>
            </div>
            <div class="skill-category-card">
              <h3>ERP & Database</h3>
              <p>Odoo ERP Deployment, CRM Implementation, SQL Query Writing, Process Automation</p>
              <div class="skill-tags">
                <span class="tag">Odoo</span>
                <span class="tag">CRM</span>
                <span class="tag">SQL</span>
              </div>
            </div>
            <div class="skill-category-card">
              <h3>DevOps</h3>
              <p>Docker (Self-hosted deployments), Containerized Odoo, Linux-based service management</p>
              <div class="skill-tags">
                <span class="tag">Docker</span>
                <span class="tag">Linux</span>
                <span class="tag">Containers</span>
              </div>
            </div>
            <div class="skill-category-card">
              <h3>Education</h3>
              <p>Associate Degree in Software Engineering (IT), Islamic Azad University, Mashhad. MTCNA Certified.</p>
              <div class="skill-tags">
                <span class="tag">MTCNA</span>
                <span class="tag">Azad University</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="section-space border-t experience-bg">
      <div class="container-x">
        <div class="exp-layout">
          <div class="exp-header">
            <span class="section-label">My Journey</span>
            <h2 class="section-title">Where I've Worked</h2>
            <p class="section-desc">
              Building expertise across networking, VoIP, and enterprise systems
              through hands-on roles in the Iranian tech ecosystem.
            </p>
          </div>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-dot" style="background: var(--accent)"></div>
              <div class="timeline-content">
                <span class="timeline-role">Hamyar Hooshmand Chabok</span>
                <span class="timeline-date">2024 - Present</span>
                <h3>Software Support Specialist</h3>
                <p>Odoo ERP deployment and structured client support. Business workflow implementation and CRM setup. Custom reporting and advanced troubleshooting.</p>
                <div class="skill-tags">
                  <span class="tag">Odoo</span>
                  <span class="tag">SQL</span>
                  <span class="tag">CRM</span>
                </div>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot" style="background: var(--accent)"></div>
              <div class="timeline-content">
                <span class="timeline-role">Sazeh Hesab</span>
                <span class="timeline-date">2023 - 2024</span>
                <h3>Technical Support Specialist</h3>
                <p>Financial software support and database troubleshooting. Optimized SQL queries for issue resolution. End-user training and structured support process.</p>
                <div class="skill-tags">
                  <span class="tag">SQL</span>
                  <span class="tag">Support</span>
                </div>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot" style="background: #7fd4c6"></div>
              <div class="timeline-content">
                <span class="timeline-role">Nasim Ertebat Ayandeh</span>
                <span class="timeline-date">2020 - 2021</span>
                <h3>VoIP & Network Support</h3>
                <p>VoIP deployment for multiple business environments. Router and switch configuration (MikroTik, Cisco). Network and voice traffic troubleshooting.</p>
                <div class="skill-tags">
                  <span class="tag">Asterisk</span>
                  <span class="tag">MikroTik</span>
                  <span class="tag">VoIP</span>
                </div>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot" style="background: #7fd4c6"></div>
              <div class="timeline-content">
                <span class="timeline-role">Shahr IT</span>
                <span class="timeline-date">2019 - 2020</span>
                <h3>IT Helpdesk</h3>
                <p>End-user IT support and system deployment. Hardware/software troubleshooting. Internal network maintenance.</p>
                <div class="skill-tags">
                  <span class="tag">IT Support</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="section-space border-t">
      <div class="container-x">
        <span class="section-label">Featured Work</span>
        <h2 class="section-title">Projects</h2>
        <p class="section-desc">
          Key infrastructure projects that demonstrate my ability to design,
          deploy, and maintain complex technical systems.
        </p>
        <div class="projects-list">
          <article class="project-row">
            <span class="project-number">01</span>
            <div class="project-info">
              <span class="project-category">VoIP Infrastructure</span>
              <h3 class="project-title">Multi-Sector VoIP Deployment</h3>
              <p class="project-desc">Implemented VoIP services for a hotel, residential complex, taxi service center and trading companies. Configured Asterisk/Issabel servers, IVR, call queues and SIP trunks.</p>
              <div class="project-metric">
                <span class="metric-value">4</span>
                <span class="metric-label">Business Sectors</span>
              </div>
              <div class="skill-tags">
                <span class="tag">Asterisk</span>
                <span class="tag">Issabel</span>
                <span class="tag">SIP</span>
                <span class="tag">IVR</span>
              </div>
            </div>
          </article>

          <article class="project-row">
            <span class="project-number">02</span>
            <div class="project-info">
              <span class="project-category">Network & Virtualization</span>
              <h3 class="project-title">Enterprise Network Design</h3>
              <p class="project-desc">Designed and implemented secure LAN infrastructure including VLAN segmentation, firewall rules and VPN access. Deployed VMware ESXi virtualization environment.</p>
              <div class="project-metric">
                <span class="metric-value">20</span>
                <span class="metric-label">Users Supported</span>
              </div>
              <div class="skill-tags">
                <span class="tag">MikroTik</span>
                <span class="tag">VMware</span>
                <span class="tag">VLAN</span>
                <span class="tag">VPN</span>
              </div>
            </div>
          </article>

          <article class="project-row">
            <span class="project-number">03</span>
            <div class="project-info">
              <span class="project-category">ERP & Business Systems</span>
              <h3 class="project-title">Odoo ERP Deployment</h3>
              <p class="project-desc">Installed and configured Odoo ERP including CRM and sales modules. Automated internal workflows and improved reporting structure for management team.</p>
              <div class="project-metric">
                <span class="metric-value">30</span>
                <span class="metric-label">Users Onboarded</span>
              </div>
              <div class="skill-tags">
                <span class="tag">Odoo</span>
                <span class="tag">CRM</span>
                <span class="tag">SQL</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section-space border-t">
      <div class="container-x">
        <div class="contact-layout">
          <div class="contact-left">
            <span class="section-label">Contact</span>
            <h2 class="section-title">Let's Work Together</h2>
            <p class="section-desc">
              Open to new opportunities and collaborations in network infrastructure,
              VoIP systems, and IT consulting. Based in Mashhad, Iran.
            </p>
            <div class="contact-badge">
              <span class="badge-dot"></span>
              <span class="eyebrow" style="color: var(--accent)">Available for opportunities</span>
            </div>
            <div class="contact-actions">
              <a href="mailto:hooshmandm43@gmail.com" class="btn btn-accent">Send Email</a>
              <a href="https://linkedin.com/in/mahdi-hooshmand" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
            </div>
          </div>
          <div class="contact-card">
            <div class="contact-info-row">
              <span class="eyebrow">Email</span>
              <a href="mailto:hooshmandm43@gmail.com" class="contact-value">hooshmandm43@gmail.com</a>
            </div>
            <div class="contact-info-row">
              <span class="eyebrow">Phone</span>
              <span class="contact-value">+98 936 826 5361</span>
            </div>
            <div class="contact-info-row">
              <span class="eyebrow">Location</span>
              <span class="contact-value">Mashhad, Iran</span>
            </div>
            <div class="contact-info-row">
              <span class="eyebrow">LinkedIn</span>
              <a href="https://linkedin.com/in/mahdi-hooshmand" target="_blank" rel="noopener noreferrer" class="contact-value">/in/mahdi-hooshmand</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer border-t">
    <div class="container-x footer-inner">
      <div class="footer-left">
        <span class="brand-sm">MAHDI<span class="accent-dot">.</span></span>
        <span class="footer-copy">&copy; 2026 Mahdi Hooshmand</span>
      </div>
      <div class="footer-right">
        <a href="#about">About</a>
        <a href="#skills">Skills</a>
        <a href="#experience">Experience</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* LOADER */
  .loader { position: fixed; inset: 0; z-index: 100; background: var(--bg); display: grid; place-items: center; transition: opacity 0.3s; }
  .loader.hide { opacity: 0; pointer-events: none; }
  .loader-inner { text-align: center; }
  .loader-name { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--fg); letter-spacing: 0.1em; display: block; margin-bottom: 20px; }
  .loader-bar { width: 200px; height: 2px; background: var(--line); margin: 0 auto 12px; overflow: hidden; }
  .loader-fill { width: 0%; height: 100%; background: var(--accent); animation: loader-fill 1s ease-out forwards; }
  @keyframes loader-fill { to { width: 100%; } }
  .loader-status { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--fg-faint); }

  /* HEADER */
  .site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 50; border-bottom: 1px solid transparent; background: rgba(10,10,15,0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transition: border-color 0.3s; }
  .site-header.scrolled { border-bottom-color: var(--line); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 72px; }
  .brand { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; color: #fff; letter-spacing: 0.05em; }
  .accent-dot { color: var(--accent); }
  .header-nav { display: flex; align-items: center; gap: 32px; }
  .nav-link { font-size: 13px; color: var(--fg-muted); transition: color 0.2s; letter-spacing: 0.02em; }
  .nav-link:hover { color: var(--fg); }
  .nav-cta { border: 1px solid var(--accent); color: var(--accent); padding: 8px 20px; border-radius: 9999px; font-size: 13px; transition: all 0.2s; }
  .nav-cta:hover { background: var(--accent); color: var(--bg); }
  .hamburger { display: none; flex-direction: column; gap: 6px; background: none; border: none; cursor: pointer; padding: 8px; }
  .hamburger span { display: block; width: 22px; height: 1.5px; background: var(--fg); transition: all 0.3s; }
  .hamburger.active span:first-child { transform: rotate(45deg) translate(2.5px, 2.5px); }
  .hamburger.active span:last-child { transform: rotate(-45deg) translate(2.5px, -2.5px); }

  /* HERO */
  .hero { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; }
  .hero-glow { position: absolute; right: 10%; top: 20%; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(233,184,114,0.06) 0%, transparent 60%); filter: blur(80px); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; padding: 120px 0 80px; }
  .hero-text { max-width: 720px; }
  .hero-eyebrows { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
  .eyebrow-sep { color: var(--fg-faint); font-size: 11px; }
  h1 { margin-bottom: 24px; }
  .name-first { display: block; }
  .name-last { display: block; color: var(--fg-muted); }
  .hero-desc { font-size: 20px; line-height: 1.75; color: var(--fg-muted); max-width: 560px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 48px; }
  .scroll-hint { display: inline-flex; align-items: center; gap: 12px; font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--fg-faint); transition: color 0.2s; }
  .scroll-hint:hover { color: var(--accent); }
  .scroll-line { display: block; width: 1px; height: 40px; background: var(--line); animation: scroll-pulse 2s ease-in-out infinite; }
  @keyframes scroll-pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 12px 28px; border-radius: 9999px; font-size: 14px; font-weight: 500; transition: all 0.2s; cursor: pointer; }
  .btn-accent { background: var(--accent); color: var(--bg); border: 1px solid var(--accent); }
  .btn-accent:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(233,184,114,0.25); }
  .btn-outline { background: transparent; color: var(--fg); border: 1px solid var(--line); }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  /* ABOUT */
  .about-bg { background: radial-gradient(120% 80% at 75% 30%, rgba(233,184,114,0.03) 0%, transparent 55%); }
  .about-layout { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: start; }
  .about-text { font-size: 15px; line-height: 1.7; color: var(--fg-muted); margin-bottom: 20px; }
  .about-card { border: 1px solid var(--line); border-radius: 12px; padding: 28px; background: var(--bg-card); margin-bottom: 16px; }
  .about-card p { font-size: 14px; line-height: 1.7; color: var(--fg-muted); margin-top: 12px; }

  /* SECTIONS */
  .section-title { margin-top: 12px; margin-bottom: 16px; }
  .section-desc { font-size: 16px; line-height: 1.7; color: var(--fg-muted); max-width: 560px; margin-bottom: 48px; }

  /* SKILLS */
  .skills-layout { display: grid; grid-template-columns: 1fr 1.2fr; gap: 64px; align-items: start; }
  .skills-text p { font-size: 15px; line-height: 1.7; color: var(--fg-muted); margin-bottom: 20px; }
  .skill-badges-inline { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
  .skill-category-card { border: 1px solid var(--line); border-radius: 12px; padding: 24px; background: var(--bg-card); margin-bottom: 12px; transition: border-color 0.3s; }
  .skill-category-card:hover { border-color: rgba(233, 184, 114, 0.3); }
  .skill-category-card h3 { font-size: 1rem; margin-bottom: 8px; }
  .skill-category-card p { font-size: 13px; line-height: 1.6; color: var(--fg-muted); margin-bottom: 12px; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 10px; border: 1px solid var(--line-soft); border-radius: 9999px; color: var(--fg-muted); }

  /* EXPERIENCE */
  .experience-bg { background: radial-gradient(120% 80% at 75% 30%, rgba(233,184,114,0.03) 0%, transparent 55%); }
  .exp-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start; }
  .exp-header { position: sticky; top: 100px; }
  .timeline { display: flex; flex-direction: column; gap: 0; border-left: 1px solid var(--line); padding-left: 32px; }
  .timeline-item { position: relative; padding: 32px 0; border-bottom: 1px solid var(--line); }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-dot { position: absolute; left: -39px; top: 36px; width: 12px; height: 12px; border-radius: 50%; border: 3px solid var(--bg); }
  .timeline-role { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); display: block; }
  .timeline-date { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-faint); display: block; margin-top: 4px; margin-bottom: 8px; }
  .timeline-content h3 { font-size: 1.4rem; margin-bottom: 12px; }
  .timeline-content p { font-size: 15px; line-height: 1.7; color: var(--fg-muted); max-width: 52ch; margin-bottom: 16px; }

  /* PROJECTS */
  .projects-list { display: flex; flex-direction: column; gap: 0; }
  .project-row { display: flex; gap: 24px; align-items: flex-start; padding: 48px 0; border-bottom: 1px solid var(--line); }
  .project-row:first-child { padding-top: 0; }
  .project-row:last-child { border-bottom: none; }
  .project-number { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg-faint); flex-shrink: 0; padding-top: 4px; }
  .project-info { flex: 1; }
  .project-category { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); display: block; margin-bottom: 8px; }
  .project-title { font-size: 1.5rem; margin-bottom: 12px; color: #fff; }
  .project-desc { font-size: 15px; line-height: 1.7; color: var(--fg-muted); margin-bottom: 20px; }
  .project-metric { display: flex; align-items: baseline; gap: 8px; padding-top: 16px; border-top: 1px solid var(--line); }
  .metric-value { font-family: 'Fraunces', serif; font-size: 1.5rem; color: var(--accent); }
  .metric-label { font-size: 13px; color: var(--fg-muted); }

  /* CONTACT */
  .contact-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .contact-badge { display: inline-flex; align-items: center; gap: 10px; border: 1px solid rgba(233,184,114,0.3); border-radius: 9999px; padding: 8px 20px; margin-bottom: 32px; }
  .badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .contact-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .contact-card { border: 1px solid var(--line); border-radius: 16px; padding: 32px; background: var(--bg-card); }
  .contact-info-row { padding: 16px 0; border-bottom: 1px solid var(--line); }
  .contact-info-row:last-child { border-bottom: none; }
  .contact-info-row .eyebrow { display: block; margin-bottom: 6px; }
  .contact-value { font-size: 15px; color: var(--fg); transition: color 0.2s; }
  a.contact-value:hover { color: var(--accent); }

  /* FOOTER */
  .site-footer { padding: 32px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: center; }
  .footer-left { display: flex; align-items: center; gap: 16px; }
  .brand-sm { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #fff; }
  .footer-copy { font-size: 12px; color: var(--fg-faint); }
  .footer-right { display: flex; gap: 24px; }
  .footer-right a { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg-faint); transition: color 0.2s; }
  .footer-right a:hover { color: var(--fg); }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .about-layout { grid-template-columns: 1fr; gap: 40px; }
    .skills-layout { grid-template-columns: 1fr; gap: 40px; }
    .project-row { grid-template-columns: 1fr; gap: 24px; }
    .exp-layout { grid-template-columns: 1fr; gap: 40px; }
    .exp-header { position: static; }
  }
  @media (max-width: 768px) {
    .header-nav { display: none; position: fixed; top: 72px; left: 0; right: 0; background: rgba(10,10,15,0.95); backdrop-filter: blur(12px); padding: 24px; flex-direction: column; gap: 20px; border-bottom: 1px solid var(--line); }
    .header-nav.open { display: flex; }
    .hamburger { display: flex; }
    .hero-eyebrows { flex-direction: column; align-items: flex-start; gap: 4px; }
    .eyebrow-sep { display: none; }
    .about-layout { grid-template-columns: 1fr; gap: 40px; }
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
    .footer-inner { flex-direction: column; gap: 16px; text-align: center; }
    .footer-right { flex-wrap: wrap; justify-content: center; }
    .hero-glow { display: none; }
    .project-row { flex-direction: column; gap: 12px; }
  }
</style>

<script is:inline>
function initAnimations() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    setTimeout(initAnimations, 100);
    return;
  }

  // Loader
  setTimeout(function() {
    var loader = document.getElementById('loader');
    if (loader) loader.classList.add('hide');
  }, 1200);

  // Header scroll effect
  var header = document.getElementById('site-header');
  window.addEventListener('scroll', function() {
    header.classList.toggle('scrolled', window.scrollY > 50);
  });

  // Register GSAP ScrollTrigger
  gsap.registerPlugin(ScrollTrigger);

  // Hero animations
  gsap.from('.hero-eyebrows', {
    opacity: 0, y: 20, duration: 0.8, delay: 0.3,
    ease: 'power3.out'
  });
  gsap.from('h1 .name-first', {
    opacity: 0, y: 30, duration: 0.8, delay: 0.5,
    ease: 'power3.out'
  });
  gsap.from('h1 .name-last', {
    opacity: 0, y: 30, duration: 0.8, delay: 0.65,
    ease: 'power3.out'
  });
  gsap.from('.hero-desc', {
    opacity: 0, y: 20, duration: 0.8, delay: 0.8,
    ease: 'power3.out'
  });
  gsap.from('.hero-actions', {
    opacity: 0, y: 20, duration: 0.8, delay: 0.95,
    ease: 'power3.out'
  });
  gsap.from('.scroll-hint', {
    opacity: 0, y: 20, duration: 0.8, delay: 1.1,
    ease: 'power3.out'
  });

  // About section
  gsap.from('.about-left', {
    opacity: 0, x: -40, duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.about-layout', start: 'top 75%', once: true }
  });
  gsap.from('.about-card', {
    opacity: 0, y: 30, duration: 0.6, stagger: 0.15,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.about-right', start: 'top 80%', once: true }
  });

  // Section reveal animations
  gsap.utils.toArray('.section-label, .section-title, .section-desc').forEach(function(el) {
    gsap.from(el, {
      opacity: 0, y: 30, duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', once: true }
    });
  });

  // Skills section
  gsap.from('.skills-left', {
    opacity: 0, x: -40, duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.skills-layout', start: 'top 75%', once: true }
  });
  gsap.from('.skill-category-card', {
    opacity: 0, y: 30, duration: 0.6, stagger: 0.1,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.skills-right', start: 'top 80%', once: true }
  });

  // Timeline items
  gsap.utils.toArray('.timeline-item').forEach(function(item, i) {
    gsap.from(item, {
      opacity: 0, x: -30, duration: 0.7, delay: i * 0.15,
      ease: 'power3.out',
      scrollTrigger: { trigger: item, start: 'top 85%', once: true }
    });
  });

  // Project rows
  gsap.utils.toArray('.project-row').forEach(function(row) {
    gsap.from(row, {
      opacity: 0, y: 40, duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: row, start: 'top 85%', once: true }
    });
  });

  // Contact section
  gsap.from('.contact-left', {
    opacity: 0, x: -40, duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.contact-layout', start: 'top 75%', once: true }
  });
  gsap.from('.contact-card', {
    opacity: 0, x: 40, duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.contact-layout', start: 'top 75%', once: true }
  });

  // Hamburger
  var hamburger = document.getElementById('hamburger');
  var nav = document.getElementById('header-nav');
  hamburger?.addEventListener('click', function() {
    hamburger.classList.toggle('active');
    nav.classList.toggle('open');
  });
  document.querySelectorAll('.header-nav .nav-link').forEach(function(link) {
    link.addEventListener('click', function() {
      hamburger?.classList.remove('active');
      nav?.classList.remove('open');
    });
  });

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
    anchor.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Active nav
  var sections = document.querySelectorAll('section[id]');
  var navLinks = document.querySelectorAll('.nav-link');
  var sectionObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function(link) {
          link.style.color = link.getAttribute('href') === '#' + entry.target.id ? 'var(--fg)' : '';
        });
      }
    });
  }, { threshold: 0.3 });
  sections.forEach(function(s) { sectionObserver.observe(s); });
}

document.addEventListener('DOMContentLoaded', initAnimations);
</script>
